APP_NAME="Smart Depot Management System API"
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./smart_depot.db
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
SECRET_KEY=change-me-in-production-please-set-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Frontend base URL used to build the login link in emails
FRONTEND_URL=http://localhost:3000

# Email / SMTP — leave SMTP_HOST empty in dev to log emails instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=no-reply@smartdepot.local
EMAIL_FROM_NAME=Smart Depot

# Automatic report scheduler (set false to disable the in-app scheduler)
ENABLE_SCHEDULER=true
# IANA timezone for report scheduling (send_hour) and labels
TIMEZONE=Africa/Kigali
